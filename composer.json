{
    "name": "huy-tran/api-explorer-module",
    "type": "laravel-module",
    "description": "Self-hosted API explorer for local development",
    "keywords": ["laravel", "api", "explorer", "development"],
    "license": "MIT",
    "authors": [
        {
            "name": "Huy Tran",
            "email": "hygo.tran@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-data": "^4.20",
        "lorisleiva/laravel-actions": "^2.10"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\ApiExplorer\\Providers\\ApiExplorerServiceProvider"
            ],
            "aliases": {}
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php artisan vendor:publish --provider=\"Modules\\ApiExplorer\\Providers\\ApiExplorerServiceProvider\" --force"
        ]
    },
    "autoload": {
        "psr-4": {
            "Modules\\ApiExplorer\\": "app/",
            "Modules\\ApiExplorer\\Database\\Factories\\": "database/factories/",
            "Modules\\ApiExplorer\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\ApiExplorer\\Tests\\": "tests/"
        }
    }
}
